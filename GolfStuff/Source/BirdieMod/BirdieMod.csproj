<Project ToolsVersion="15.0" DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <RootDir>$(MSBuildThisFileDirectory)..\..\</RootDir>
    <BuildScript>$(RootDir)compile_mod.bat</BuildScript>
    <OutputDll>$(RootDir)Mods\BirdieMod.dll</OutputDll>
  </PropertyGroup>

  <Target Name="Build">
    <Exec Command="cmd /c &quot;$(BuildScript)&quot;" WorkingDirectory="$(RootDir)" />
  </Target>

  <Target Name="Clean">
    <Delete Files="$(OutputDll)" ContinueOnError="true" />
  </Target>

  <Target Name="Rebuild" DependsOnTargets="Clean;Build" />
</Project>
